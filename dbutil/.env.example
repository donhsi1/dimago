# Copy to `.env` and fill in secrets (never commit `.env`).
# Optional: use `.env.local` for machine-only overrides (gitignored). It is loaded after `.env`
# and overrides keys from `.env` for values not already set in the OS environment.

# REST API (dbutil --commit, Flutter dart-define)
SUPABASE_URL=https://prxmhmkndgvnlrbmnyxp.supabase.co
SUPABASE_KEY=

# For dbutil --commit: use service_role JWT (Settings -> API). Anon key hits RLS on lessons/words.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: override default project ref when using bare `python dbutil.py --input x.db --commit`
# SUPABASE_PROJECT_REF=prxmhmkndgvnlrbmnyxp

# Postgres URI for SQL migrations (scripts/supabase/_apply_migration_lang_columns.py,
# migrate_sqlite_to_supabase.py). Use the Session pooler string from Supabase Dashboard
# -> Connect -> Session pooler. URL-encode special characters in the password.
# Replace YOUR_DB_PASSWORD with your database password (not the anon key).
DATABASE_URL=postgresql://postgres.prxmhmkndgvnlrbmnyxp:YOUR_DB_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres
